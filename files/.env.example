# Copy this file to .env and fill in your actual keys
# Never commit the .env file to your repository

# Required: Anthropic Claude API key
# Get yours at: https://console.anthropic.com/
GROQ_API_KEY=yourGraqKey
# Optional but recommended: GitHub Personal Access Token
# Increases rate limit from 60 to 5000 requests/hour
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=yourGithubToken

# Port the server runs on (default: 3000)
PORT=3000
